# Stream Video Network (getstream.io)
# Get these from: https://getstream.io/dashboard/
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Google AI Studio (Gemini)
# Get this from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ElevenLabs (Text-to-Speech)
# Get this from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Deepgram (Speech-to-Text)
# Get this from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
