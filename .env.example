# ============================================================
# VisitAid — Required API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# STREAM — Video call network (connects phone camera to agent)
# Handles the live video/audio connection between user and AI.
# Sign up: https://getstream.io/dashboard/
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# GOOGLE GEMINI — The AI brain (understands what the camera sees)
# Powers scene understanding, object detection, and conversation.
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ELEVENLABS — Voice output (speaks responses to the user)
# Converts AI text responses into natural-sounding speech.
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# DEEPGRAM — Voice input (hears what the user says)
# Converts user's spoken words into text for the AI to process.
# Get key: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
